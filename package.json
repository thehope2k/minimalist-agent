{
  "name": "minimalist-agent",
  "productName": "Minimalist Agent",
  "description": "A focused AI coding agent for software engineers who value simplicity — Anthropic API, Claude OAuth, and GitHub Copilot in one quiet, distraction-free desktop app.",
  "version": "1.18.0",
  "license": "MIT",
  "author": {
    "name": "The Hope",
    "url": "https://github.com/thehope2k"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thehope2k/minimalist-agent.git"
  },
  "homepage": "https://github.com/thehope2k/minimalist-agent#readme",
  "bugs": {
    "url": "https://github.com/thehope2k/minimalist-agent/issues"
  },
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "postinstall": "node scripts/rebuild-native.mjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "generate-icons": "node scripts/generate-icons.mjs",
    "pack": "npm run generate-icons && electron-vite build && electron-builder --publish never",
    "release": "npm run generate-icons && electron-vite build && electron-builder --publish always",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.92.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.217",
    "@earendil-works/pi-ai": "^0.81.1",
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@vscode/ripgrep": "^1.18.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.6",
    "minimatch": "^10.2.5",
    "node-pty": "^1.0.0",
    "sharp": "^0.35.2",
    "sherpa-onnx-node": "^1.13.4",
    "tar": "^7.5.20",
    "unbzip2-stream": "^1.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/runtime": "^8.0.0",
    "@electron/rebuild": "^4.0.4",
    "@fontsource/cascadia-code": "^5.2.3",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@types/mark.js": "^8.11.12",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tar": "^6.1.13",
    "@types/unbzip2-stream": "^1.4.3",
    "@uiw/react-json-view": "^2.0.0-alpha.43",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.6",
    "electron-vite": "^5.0.0",
